{
  "name": "ryzokuken.github.io",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "build:css": "mkdir -p _site/css && lightningcss --minify --bundle src/css/main.css -o _site/css/main.css",
    "build": "eleventy && pnpm run build:css",
    "dev": "eleventy --serve",
    "lint": "markuplint \"src/**/*.{html,liquid,md}\"",
    "test:links": "linkinator _site --skip /slides/",
    "test": "pnpm run build && pnpm run lint && pnpm run test:links",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.33.2",
  "repository": "github:ryzokuken/ryzokuken.github.io",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ryzokuken/ryzokuken.github.io/issues"
  },
  "homepage": "https://github.com/ryzokuken/ryzokuken.github.io#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@kevingimbel/eleventy-plugin-mermaid": "^3.0.1",
    "husky": "^9.1.7",
    "lightningcss-cli": "^1.32.0",
    "linkinator": "^7.6.1",
    "lint-staged": "^16.4.0",
    "markuplint": "^4.18.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["lightningcss-cli"]
  }
}
