<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <meta name="description" content="{{ description | default: "Ujjwal Sharma — Developer Advocate at Igalia, TC39 Co-chair, ECMA-402 Co-editor." }}">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description | default: "Ujjwal Sharma — Developer Advocate at Igalia, TC39 Co-chair, ECMA-402 Co-editor." }}">
  <meta property="og:type" content="website">
  <title>{{ title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <nav id="navbar" aria-label="Main navigation">
    <ul>
      <li><a href="/"{% if page.url == "/" %} aria-current="page"{% endif %}>Home</a></li>
      <li><a href="/talks/"{% if page.url contains "/talks/" %} aria-current="page"{% endif %}>Talks</a></li>
      <li><a href="/slides/"{% if page.url contains "/slides/" %} aria-current="page"{% endif %}>Slides</a></li>
      <li><a href="/projects/"{% if page.url contains "/projects/" %} aria-current="page"{% endif %}>Projects</a></li>
      <li><a href="/blog/"{% if page.url contains "/blog/" %} aria-current="page"{% endif %}>Blog</a></li>
      <li><a href="/uses/"{% if page.url contains "/uses/" %} aria-current="page"{% endif %}>Uses</a></li>
    </ul>
  </nav>
  <main id="main-content" class="container">
    {{ content }}
  </main>
  <footer id="footer">
    <p>Made with ❤️ by <a href="https://mastodon.social/@ryzokuken">Ryzokuken</a> using <a href="https://www.11ty.dev/">11ty</a></p>
  </footer>
  <script src="https://unpkg.com/@twemoji/api@15.1.0/dist/twemoji.min.js" integrity="sha384-o28+zJO3/45GHIy+9TFKGaYnbt0KQcFRzyBrb0WSSrz7bPGwGI1d64worBiXPgXw" crossorigin="anonymous"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      twemoji.parse(document.body, { folder: 'svg', ext: '.svg' });
    });
  </script>
</body>
</html>
