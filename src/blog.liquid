---
layout: layout.liquid
title: Ryzokuken's Blog
---
<h1>My Blog</h1>

<div class="card-grid">
  {%- for post in collections.post reversed -%}
  <div class="card">
    <h3 style="margin-top: 0; margin-bottom: var(--space-xs);"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
    <div style="font-size: var(--font-size-sm); color: var(--text-secondary); margin-bottom: var(--space-sm);">
      📅 {{ post.date | date: "%B %d, %Y" }}
      {% assign tags = post.data.tags | slice:1,10 %}
      {% if tags.size > 0 %}
      · 🏷 {%- for tag in tags -%} <a href="/tag/{{tag}}" style="margin-left: 0.25rem;">{{tag}}</a>{%- endfor -%}
      {% endif %}
    </div>
    <p>{{ post.templateContent | strip_html | truncatewords: 40 }}</p>
  </div>
  {%- endfor -%}
</div>
