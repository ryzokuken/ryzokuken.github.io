---
layout: layout.liquid
pagination:
  data: collections
  size: 1
  alias: tag
permalink: "/tag/{{ tag }}/"
title: Posts tagged {{ tag }}
---
<h1>Posts tagged "{{tag}}"</h1>
<ul>
  {%- for post in collections[tag] reversed -%}
  <li>
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
  </li>
  {%- endfor -%}
</ul>
